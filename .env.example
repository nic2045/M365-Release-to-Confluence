# Copy to .env and fill in. .env is gitignored.

# --- Microsoft Graph (Message Center) ---
# Entra ID app registration with application permission ServiceMessage.Read.All
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=

# --- M365 roadmap (public, no auth) ---
# M365_ROADMAP_API_URL=https://www.microsoft.com/releasecommunications/api/v1/m365

# --- AI provider: anthropic | azure_openai | local ---
AI_PROVIDER=anthropic
OUTPUT_LANGUAGE=de

# Optional organisation profile injected into the (cached) system prompt so the
# Activate/Deactivate/Communicate recommendations fit your environment.
# Either inline text or a path to a file (file takes precedence).
# ORG_CONTEXT=We are a 5000-seat financial services tenant; security-first; pilot ring = IT.
# ORG_CONTEXT_FILE=./org_context.txt

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Local / OpenAI-compatible endpoint (Ollama, LM Studio, vLLM, ...)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=
LOCAL_LLM_API_KEY=not-needed

# --- Default relevance filters (optional; CLI flags override these) ---
# Comma-separated. Substring match for products, exact for categories.
# FILTER_PRODUCTS=Teams,Exchange
# FILTER_CATEGORIES=planForChange,preventOrFixIssue
# FILTER_MAJOR_ONLY=false
# FILTER_ACTION_REQUIRED=false
# FILTER_WORLDWIDE_ONLY=true   # roadmap: keep only the Worldwide cloud instance
# FILTER_QUARTER=Q3 2026

# --- Confluence Server / Data Center ---
CONFLUENCE_BASE_URL=https://confluence.example.com
# Personal Access Token. CONFLUENCE_TOKEN takes precedence; ConfluencePAT also works.
CONFLUENCE_TOKEN=
# ConfluencePAT=
CONFLUENCE_SPACE=
CONFLUENCE_PARENT_PAGE_ID=
